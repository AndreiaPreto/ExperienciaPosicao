{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and registration data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "description": "Email address" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "paidStatus": { "type": "boolean", "description": "Whether the user has paid for access" },
        "clube_ativo": { "type": "boolean", "description": "Whether the user has an active club subscription" },
        "subscriptionStatus": { "type": "string", "description": "Stripe subscription status" },
        "subscriptionId": { "type": "string", "description": "Stripe subscription ID" },
        "lastPaymentAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "whatsapp", "role"]
    },
    "Diagnostico": {
      "title": "Diagnostico",
      "description": "User diagnostic results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "archetype": { "type": "string" },
        "theme": { "type": "string" },
        "answers": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "archetype", "theme"]
    },
    "Mapping": {
      "title": "Mapping",
      "description": "Emotional mapping results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "emocao": { "type": "string" },
        "padrao": { "type": "string" },
        "defesa": { "type": "string" },
        "ferida": { "type": "string" },
        "desejo": { "type": "string" },
        "arquetipo": { "type": "string" },
        "florais": { "type": "string" },
        "result": { "type": "string" },
        "alignmentScore": { "type": "number" }
      },
      "required": ["userId", "createdAt", "emocao", "padrao", "defesa", "ferida", "desejo", "arquetipo", "florais", "result", "alignmentScore"]
    },
    "ReprogramacaoRequest": {
      "title": "ReprogramacaoRequest",
      "description": "User request for personal frequency audio",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productName": { "type": "string" },
        "estadoEmocional": { "type": "string" },
        "objetivo": { "type": "string" },
        "observacoes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "estadoEmocional", "objetivo", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons for services",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The coupon code (e.g., POSICAO10)" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"], "description": "Type of discount" },
        "value": { "type": "number", "description": "Discount value (percentage or amount in BRL)" },
        "active": { "type": "boolean", "description": "Whether the coupon is active" },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Optional expiry date" }
      },
      "required": ["code", "discountType", "value", "active"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "User scheduled appointments",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "time": { "type": "string", "description": "HH:MM" },
        "productName": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "time", "productName", "status", "createdAt"]
    },
    "ClubeClarearWaitlist": {
      "title": "ClubeClarearWaitlist",
      "description": "Waitlist entries for Clube Clarear",
      "type": "object",
      "properties": {
        "nome": { "type": "string", "description": "User's name" },
        "email": { "type": "string", "description": "User's email" },
        "inscrito_em": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "notificado": { "type": "boolean", "description": "Whether the user was notified yet" }
      },
      "required": ["nome", "email", "inscrito_em", "notificado"]
    },
    "Product": {
      "title": "Product",
      "description": "Products available in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["one_time", "subscription", "library", "monthly"] },
        "active": { "type": "boolean" },
        "order": { "type": "number" },
        "legacyNames": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "category", "type", "active", "order"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products list"
    },
    "/diagnosticos/{diagId}": {
      "schema": "Diagnostico",
      "description": "Diagnostic results"
    },
    "/mappings/{mappingId}": {
      "schema": "Mapping",
      "description": "Emotional mapping results"
    },
    "/reprogramacao_requests/{requestId}": {
      "schema": "ReprogramacaoRequest",
      "description": "Requests for personal frequency audio"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "User appointments"
    },
    "/clube_clarear_waitlist/{waitlistId}": {
      "schema": "ClubeClarearWaitlist",
      "description": "Waitlist for Clube Clarear"
    }
  }
}
